generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?   // Full name, computed from first + last
  firstName       String?
  lastName        String?
  phone           String?
  role            UserRole  @default(OWNER)
  image           String?
  emailVerified   DateTime?
  // Password auth. Nullable so existing users still exist without a
  // password; they are blocked from logging in until an admin runs
  // scripts/set-user-password.ts or they go through a reset flow.
  passwordHash    String?
  passwordSetAt   DateTime?
  stripeCustomerId String?
  referralSource  String?   // How they heard about us
  marketingOptIn  Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  agencies AgencyMember[]
}

enum UserRole {
  OWNER
  PHOTOGRAPHER
  EDITOR
  MANAGER
  OTHER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agency {
  id        String   @id @default(cuid())
  name      String

  // Business profile
  website         String?
  phone           String?
  addressCity     String?
  addressState    String?
  addressZip      String?
  teamSize        String?   // "1", "2-5", "6-10", "11-25", "26+"
  propertiesMonth String?   // "<10", "10-25", "26-50", "51-100", "100+"
  yearsInBusiness String?   // "<1", "1-3", "4-7", "8+"
  serviceTypes    String[]  // ["residential", "commercial", "drone", "video", "3d"]

  // Platforms they currently use (for migration guidance)
  currentPlatforms String[] // ["aryeo", "hdphotohub", "spiro", "tonomo", "dropbox", "none"]

  // Credits system - 1 credit = 1 property processed
  creditBalance       Int      @default(0)
  hasPaymentMethod    Boolean  @default(false)
  billingMode         BillingMode @default(CREDITS)
  totalCreditsPurchased Int    @default(0)

  // Onboarding progress
  onboardingComplete Boolean @default(false)

  // Admin / test mode - bypasses credit checks
  isAdmin            Boolean @default(false)

  // Per-agency staging price override. Null = use STAGING_CREDIT_COST
  // default (3). Non-null = use this value instead. Used to give
  // partner / internal agencies discounted rates without affecting
  // anyone else.
  stagingCreditCost  Int?


  // Default tier applied when creating new properties
  defaultTier        PropertyTier @default(STANDARD)

  // Default distraction removal categories applied on new Premium properties.
  // Empty array means the check is skipped. Safe defaults suggested in the UI
  // are trash_bin / garden_hose / kids_toy / cables / etc. Risky ones
  // (parked_car, satellite_dish, power_line) require explicit opt-in.
  distractionCategoriesDefault String[] @default([])

  // Auto-sort photos by room type on QC review, downloads, and pushes.
  // When autoSortEnabled is true the UI and export flows order photos
  // by the room-type sequence in photoSortOrder. Unknown / unclassified
  // photos fall to the end in upload order.
  autoSortEnabled Boolean @default(false)
  photoSortOrder  String[] @default(["exterior_front", "exterior_back", "exterior_pool", "living_room", "dining_room", "kitchen", "bedroom", "bathroom", "office", "hallway", "basement", "other"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       AgencyMember[]
  styleProfiles StyleProfile[]
  clients       ClientProfile[]
  properties    Property[]
  integrations  Integration[]
  creditTransactions CreditTransaction[]
  referralCode  ReferralCode?
}

model ReferralCode {
  id        String           @id @default(cuid())
  agencyId  String           @unique
  code      String           @unique
  createdAt DateTime         @default(now())

  agency  Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  invites ReferralInvite[]
}

// One row per email invited. status walks PENDING -> SIGNED_UP -> CREDITED.
// EXPIRED if 90 days elapse without progress.
model ReferralInvite {
  id               String         @id @default(cuid())
  codeId           String
  inviteeEmail     String
  status           ReferralStatus @default(PENDING)
  signedUpUserId   String?
  signedUpAgencyId String?
  creditedAt       DateTime?
  creditsEarned    Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  code ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([codeId, inviteeEmail])
  @@index([inviteeEmail])
  @@index([signedUpAgencyId])
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  CREDITED
  EXPIRED
}

// Live support chat. One conversation per user (or anon visitor with a
// cookie-set visitorId). Messages stored verbatim so Paul can review
// what users actually ask + how the AI is answering. Open conversations
// stay around forever; could be archived after N days as needed.
model SupportConversation {
  id         String           @id @default(cuid())
  userId     String?
  agencyId   String?
  visitorId  String?          // for anonymous chat visitors
  status     String           @default("OPEN")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  messages   SupportMessage[]

  @@index([userId])
  @@index([agencyId])
  @@index([visitorId])
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           String              // "user" | "assistant"
  content        String              @db.Text
  createdAt      DateTime            @default(now())

  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum BillingMode {
  CREDITS        // Pre-purchased credits ($10/property)
  PAY_AS_YOU_GO  // Card charged per property ($12/property)
}

model AgencyMember {
  id       String @id @default(cuid())
  userId   String
  agencyId String
  role     String @default("member") // "owner", "admin", "member"

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([userId, agencyId])
}

model StyleProfile {
  id                 String  @id @default(cuid())
  agencyId           String
  name               String
  isDefault          Boolean @default(false)

  // Learned parameters from reference photos
  colorTempMin       Float?  // Kelvin
  colorTempMax       Float?
  colorTempAvg       Float?
  saturationMin      Float?
  saturationMax      Float?
  saturationAvg      Float?
  contrastMin        Float?
  contrastMax        Float?
  contrastAvg        Float?
  exposureMin        Float?
  exposureMax        Float?
  exposureAvg        Float?
  verticalTolerance  Float   @default(1.0) // degrees
  sharpnessThreshold Float   @default(100.0) // Laplacian variance

  // Reference photo S3 keys
  referencePhotos    String[] // S3 keys of approved reference photos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency  Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  clients ClientProfile[]
}

model ClientProfile {
  id              String  @id @default(cuid())
  agencyId        String
  styleProfileId  String? // inherits from this style profile
  clientName      String
  clientEmail     String?
  clientPhone     String?

  // Overrides (null means inherit from style profile)
  colorTempOverride    Float?
  saturationOverride   Float?
  contrastOverride     Float?
  exposureOverride     Float?
  verticalTolOverride  Float?
  customNotes          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  styleProfile StyleProfile? @relation(fields: [styleProfileId], references: [id])
  properties   Property[]
}

model Property {
  id              String   @id @default(cuid())
  agencyId        String
  clientProfileId String?
  address         String
  status          PropertyStatus @default(PENDING)
  tier            PropertyTier   @default(STANDARD)

  // Per-property distraction categories enabled for removal. Inherits
  // from Agency.distractionCategoriesDefault on create unless overridden.
  // Only runs when tier == PREMIUM AND this list is non-empty.
  distractionCategories String[] @default([])

  // True for property rows auto-created by the standalone Virtual
  // Staging tab. The main Properties list filters these out so they do
  // not pollute the QC workflow. Photos attached to these properties
  // still go through the normal QC pipeline to get room_type
  // classification, and the Virtual Staging button lights up on
  // eligible rooms once classification completes.
  isStandaloneStaging Boolean @default(false)

  // AutoHDR-via-Dropbox ingest tracking. When a property is auto-created
  // by the Dropbox watcher we record the source folder path and the
  // integration id here. After QC finishes we use these to push the
  // finished files back to the source folder's "/Processed" subfolder.
  // dropboxPushedAt is set after a successful push-back so the cron
  // does not push the same property twice.
  dropboxSourceFolder String?
  dropboxIntegrationId String?
  dropboxPushedAt     DateTime?

  photoCount      Int      @default(0)
  qcPassCount     Int      @default(0)
  qcFailCount     Int      @default(0)
  totalQcScore    Float?
  pushedAt        DateTime?
  pushedTo        String?  // platform name

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency  Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client  ClientProfile? @relation(fields: [clientProfileId], references: [id])
  photos  Photo[]
}

enum PropertyStatus {
  PENDING      // uploaded, not yet processed
  PROCESSING   // QC in progress
  REVIEW       // needs human review
  APPROVED     // all photos pass
  PUSHED       // delivered to platform
}

enum PropertyTier {
  STANDARD     // 1 credit - full QC, no privacy blur
  PREMIUM      // 2 credits - everything + privacy blur + AI deblur
}

model Photo {
  id            String      @id @default(cuid())
  propertyId    String
  fileName      String
  s3KeyOriginal String      // original upload
  s3KeyFixed    String?     // auto-corrected version
  status        PhotoStatus @default(PENDING)
  qcScore       Float?      // 0-100
  fileSize      Int?        // bytes

  // QC results
  verticalDev   Float?  // degrees off vertical
  horizonDev    Float?  // degrees off horizontal
  colorTemp     Float?  // detected color temperature
  exposure      Float?  // exposure value
  sharpness     Float?  // Laplacian variance
  saturation    Float?  // average saturation

  // Issue flags
  issues        Json?   // detailed issue breakdown
  aiNotes       String? @db.Text // Claude Vision analysis

  // Fix tracking
  fixesApplied  String[] // list of auto-fixes applied
  fixedAt       DateTime?

  // When true, exports, pushes, and the UI all serve the original bytes
  // instead of s3KeyFixed. User-driven override for cases where the
  // auto-fix made things worse. The fixed artifact is kept on S3 so the
  // user can flip back without re-queueing QC.
  useOriginal   Boolean   @default(false)

  // Add-on variants (Virtual Twilight so far). When TWILIGHT_FINAL
  // exists, downloads and pushes include it alongside the main output.
  variants      PhotoVariant[]

  // Virtual Staging unlock: timestamp of the first 2-credit charge on
  // this photo. Once set, every preview + every keeper render on this
  // photo is free for the user. Eliminates the "preview spam, never
  // buy" margin drain on the gpt-image-1 model.
  stagingUnlockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Prevents duplicate rows when parallel ingest runs (webhook + cron,
  // or Dropbox retries) land on the same file simultaneously. The
  // ingest code also catches the P2002 from this constraint and skips.
  @@unique([propertyId, fileName])
}

enum PhotoStatus {
  PENDING     // not yet checked
  PROCESSING  // QC running
  PASSED      // all checks pass
  FIXED       // auto-corrected, now passes
  FLAGGED     // needs human review
  APPROVED    // human approved
  REJECTED    // human rejected
}

model Integration {
  id          String @id @default(cuid())
  agencyId    String
  platform    IntegrationPlatform
  isActive    Boolean @default(true)

  // Encrypted credentials stored as JSON
  credentials Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, platform])
}

enum IntegrationPlatform {
  ARYEO
  HDPHOTOHUB
  SPIRO
  TONOMO
  DROPBOX_AUTOHDR
}

model UsageRecord {
  id          String   @id @default(cuid())
  agencyId    String
  propertyId  String
  photoCount  Int
  tierPrice   Int      // cents (the actual amount charged or credit value)
  billingMode BillingMode
  creditsUsed Int      @default(1)
  stripeChargeId String?  // Stripe PaymentIntent ID if PAYG

  createdAt DateTime @default(now())
}

model CreditTransaction {
  id          String   @id @default(cuid())
  agencyId    String
  type        CreditTransactionType
  amount      Int      // credits added (positive) or used (negative)
  priceCents  Int?     // Cost in cents (only for purchases)
  stripeChargeId String?
  description String?

  createdAt DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

enum CreditTransactionType {
  PURCHASE       // Bought credits via Stripe
  USAGE          // Used credits to process a property
  REFUND         // Refunded credits (property failed QC processing)
  ADJUSTMENT     // Manual adjustment by admin
  PROMO          // Promotional credits
}

model CreditPackage {
  id          String @id @default(cuid())
  name        String
  credits     Int
  priceCents  Int
  savingsPct  Int    @default(0)
  isActive    Boolean @default(true)
  stripePriceId String?
  displayOrder Int @default(0)
}

// Customer-submitted bug reports. Logged via the in-app "Report a bug"
// widget and triaged from the admin dashboard. Fixes land on main via a
// normal PR; the PR URL is stored here so the admin view can link out.
// When status flips to FIXED, the reporter gets notified via Resend.
// Derived versions of a Photo: right now this is Virtual Twilight
// variants (preview at 1 credit of the free tier, final at 1 paid
// credit). Leaves room for future AI add-ons (virtual staging, sky
// replacement, etc.) without another table.
model PhotoVariant {
  id          String              @id @default(cuid())
  photoId     String
  type        PhotoVariantType
  s3Key       String
  provider    String?             // "gemini" | "leonardo" | ...
  prompt      String?             @db.Text
  // Style modifier for variants that have styled options (virtual
  // staging picks a furniture style). Null for Twilight and any other
  // single-style variant types.
  style       String?
  status      PhotoVariantStatus  @default(READY)
  creditCost  Int                 @default(0)  // credits charged for this variant, 0 = preview
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  photo       Photo               @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([photoId, type])
  @@index([photoId, type, style])
}

enum PhotoVariantType {
  TWILIGHT_PREVIEW
  TWILIGHT_FINAL
  STAGING_PREVIEW
  STAGING_FINAL
}

enum PhotoVariantStatus {
  GENERATING
  READY
  FAILED
}

model BugReport {
  id              String       @id @default(cuid())
  reporterUserId  String
  agencyId        String?
  type            FeedbackType @default(BUG)
  title           String
  description     String       @db.Text
  severity        BugSeverity  @default(NORMAL)
  status          BugStatus    @default(NEW)
  screenshotKey   String?      // S3 key for optional screenshot
  pageUrl         String?      // where the user was when they reported
  userAgent       String?      @db.Text
  prUrl           String?      // link to the PR fixing this / shipping the feature
  fixedCommitSha  String?
  internalNotes   String?      @db.Text
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([reporterUserId])
  @@index([type])
}

enum FeedbackType {
  BUG
  FEATURE_REQUEST
}

enum BugSeverity {
  MINOR
  NORMAL
  CRITICAL
}

enum BugStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  FIXED
  WONT_FIX
}
