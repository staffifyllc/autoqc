# Database
DATABASE_URL="postgresql://user:password@localhost:5432/photoqc"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AWS
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="photoqc-uploads"
AWS_SQS_QUEUE_URL=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_BASE=""
STRIPE_PRICE_ID_MEDIUM=""
STRIPE_PRICE_ID_LARGE=""

# Claude API (for vision QC checks)
ANTHROPIC_API_KEY=""

# Replicate API (for AI deblur - optional, falls back to local sharpening if not set)
# Sign up at https://replicate.com, cost is ~$0.001 per deblur
REPLICATE_API_TOKEN=""

# Gemini (Nano Banana) for the Virtual Twilight add-on.
# Get a key at https://aistudio.google.com/apikey - free tier = 1500/day.
# Paid: $0.039/image.
GEMINI_API_KEY=""

# Resend for bug-report email notifications. Same key across autoqc and
# gostaffify projects during the beta.
RESEND_API_KEY=""

# Integrations
ARYEO_API_KEY=""
HDPHOTOHUB_API_KEY=""
DROPBOX_APP_KEY=""
DROPBOX_APP_SECRET=""
